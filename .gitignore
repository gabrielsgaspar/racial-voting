# Environment
.env

# Python caches
__pycache__/
.pytest_cache/
.ipynb_checkpoints/

# Bytecode
*.pyc

# Data outputs and local artifacts
data/raw/**
data/interim/**
data/clean/**
outputs/**

# Keep placeholder files for empty directories
!data/raw/anes/.gitkeep
!data/raw/docs/.gitkeep
!data/interim/.gitkeep
!data/clean/.gitkeep
!outputs/figures/.gitkeep
!outputs/tables/.gitkeep
!outputs/reports/.gitkeep

# Tabular and columnar data files in project data folders
data/**/*.parquet
data/**/*.csv

# Keep committed data dictionary CSV in docs
!docs/data-dictionary/anes_variables.csv
